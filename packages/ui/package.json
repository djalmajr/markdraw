{
  "name": "@asciimark/ui",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "exports": {
    "./*": "./src/*"
  },
  "scripts": {
    "test": "bun test && vitest run --config vitest.config.ts",
    "test:bun": "bun test",
    "test:vitest": "vitest run --config vitest.config.ts",
    "test:vitest:watch": "vitest --config vitest.config.ts",
    "test:coverage": "bun test --coverage && vitest run --config vitest.config.ts --coverage"
  },
  "dependencies": {
    "@asciimark/core": "workspace:*",
    "@asciimark/i18n": "workspace:*",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "@dnd-kit/solid": "^0.4.0",
    "@kobalte/core": "^0.13.11",
    "@mdit/plugin-alert": "^0.23.2",
    "class-variance-authority": "^0.7.1",
    "katex": "^0.16.22",
    "tw-animate-css": "^1.0.1",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.14.0",
    "pdfjs-dist": "^5.7.284",
    "prismjs": "^1.30.0",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.441",
    "@solidjs/testing-library": "^0.8.10",
    "@types/markdown-it": "^14.1.2",
    "@testing-library/jest-dom": "^6.5.0",
    "@vitest/coverage-v8": "^4.1.6",
    "fast-check": "^4.8.0",
    "happy-dom": "^20.8.9",
    "typescript": "^5.9.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.1.6"
  }
}
