# dependencies (bun install)
node_modules

# output
out
dist
*.tgz

# code coverage
coverage
*.lcov

# bench results (machine-specific) — but baseline.json IS committed
**/__bench__/last-run.json

# fast-check seed cache (regenerated on each run)
**/.fast-check.json

# coverage snapshots that are not gits-tracked baseline
**/coverage-summary.json
!**/__coverage__/baseline.json

# stryker mutation testing
**/.stryker-tmp
**/stryker-tmp
**/reports/mutation
packages/*/reports

# cargo-mutants artifacts
**/mutants.out
**/mutants.out.old

# fuzzing artifacts
**/fuzz/findings
**/fuzz/corpus

# logs
logs
_.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# IntelliJ based IDEs
.idea

# Tauri
apps/desktop/src-tauri/target
apps/desktop/src-tauri/llvm-cov-target

# Stand-alone Rust sub-crates under tools/ (loom-watcher-tests,
# miri-helpers-tests). Each has its own target/ and Cargo.lock.
tools/*/target
tools/*/Cargo.lock

# Finder (MacOS) folder config
.DS_Store

# Agents
.claude/*
.claude/hooks/**/.bypass
.claude/hooks/**/store.db
!.claude/commands/
!.claude/hooks/
!.claude/rules/
!.claude/settings.json

.opencode/*
!.opencode/commands/
# Track project-owned plugins and hooks (wiki-init managed files included —
# every dev should pull a working setup from git instead of having to
# re-run wiki-init locally).
!.opencode/plugins/
!.opencode/hooks/

# CLAUDE.md files (except root)
**/CLAUDE.md
!/CLAUDE.md
