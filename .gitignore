# dependencies (bun install)
node_modules

# output
out
dist
*.tgz

# code coverage
coverage
*.lcov

# bench results (machine-specific) — but baseline.json IS committed
**/__bench__/last-run.json

# fast-check seed cache (regenerated on each run)
**/.fast-check.json

# coverage snapshots that are not gits-tracked baseline
**/coverage-summary.json
!**/__coverage__/baseline.json

# stryker mutation testing
**/.stryker-tmp
**/stryker-tmp
**/reports/mutation
packages/*/reports

# cargo-mutants artifacts
**/mutants.out
**/mutants.out.old

# fuzzing artifacts
**/fuzz/findings
**/fuzz/corpus

# logs
logs
_.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# IntelliJ based IDEs
.idea

# Tauri
apps/desktop/src-tauri/target
apps/desktop/src-tauri/llvm-cov-target

# Tauri-generated permission/ACL schemas. The `tauri-build` build
# script regenerates these on every `cargo build` from the
# currently-resolved plugin versions, so they drift the moment any
# Tauri-side dep upgrades. Matches the Tauri 2 official template.
apps/desktop/src-tauri/gen/schemas/

# Stand-alone Rust sub-crates under tools/ (loom-watcher-tests,
# miri-helpers-tests). Each has its own target/ and Cargo.lock.
tools/*/target
tools/*/Cargo.lock

# Finder (MacOS) folder config
.DS_Store

# Agents — operator-local routing (MCP endpoints + agent config).
# Kept on disk but not published: versioning these leaks the personal
# MCP endpoint and forces collaborators onto a specific instance.
# The ai-memory MCP is registered globally per-operator, so the repo
# needs no per-repo MCP config.
.claude/
.codex/
opencode.json

.opencode/*
!.opencode/commands/
# Track project-owned plugins and hooks (mutation-suggest guardrail).
!.opencode/plugins/
!.opencode/hooks/

# CLAUDE.md files (except root)
**/CLAUDE.md
!/CLAUDE.md
