# dependencies (bun install)
node_modules

# output
out
dist
*.tgz

# code coverage
coverage
*.lcov

# bench results (machine-specific) — but baseline.json IS committed
**/__bench__/last-run.json

# fast-check seed cache (regenerated on each run)
**/.fast-check.json

# coverage snapshots that are not gits-tracked baseline
**/coverage-summary.json
!**/__coverage__/baseline.json

# stryker mutation testing
**/.stryker-tmp
**/stryker-tmp
**/reports/mutation
packages/*/reports

# cargo-mutants artifacts
**/mutants.out
**/mutants.out.old

# fuzzing artifacts
**/fuzz/findings
**/fuzz/corpus

# logs
logs
_.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# IntelliJ based IDEs
.idea

# Tauri
apps/desktop/src-tauri/target
apps/desktop/src-tauri/llvm-cov-target

# Tauri-generated permission/ACL schemas. The `tauri-build` build
# script regenerates these on every `cargo build` from the
# currently-resolved plugin versions, so they drift the moment any
# Tauri-side dep upgrades. Matches the Tauri 2 official template.
apps/desktop/src-tauri/gen/schemas/

# Stand-alone Rust sub-crates under tools/ (loom-watcher-tests,
# miri-helpers-tests). Each has its own target/ and Cargo.lock.
tools/*/target
tools/*/Cargo.lock

# Finder (MacOS) folder config
.DS_Store

# Operator-local ai-memory routing (never commit — would leak in the public repo):
# the workspace/project marker, and the Claude project-scope MCP config.
.ai-memory.toml
.mcp.json

# Local tooling caches / scratch (browser-MCP output, MCP tool-schema cache).
.playwright-mcp/
mcps/

# Agents — track project-owned config + guardrails (the mutation-suggest
# hook lives here, no secrets). The personal MCP endpoint is registered
# globally per-operator; the operator-local routing files above are git-ignored,
# everything below is shareable.
.claude/*
.claude/hooks/**/.bypass
.claude/hooks/**/store.db
!.claude/commands/
!.claude/hooks/
!.claude/rules/
!.claude/settings.json
# .claude/plans/ and .claude/worktrees/ stay ignored (operator-local scratch).

.opencode/*
!.opencode/commands/
!.opencode/plugins/
!.opencode/hooks/

# CLAUDE.md files (except root)
**/CLAUDE.md
!/CLAUDE.md
