{
  "manifest_version": 3,
  "name": "AsciiDoc Viewer",
  "version": "1.0.0",
  "description": "Preview AsciiDoc files with folder navigation, include:: support, and auto-refresh",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open AsciiDoc Viewer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": []
}
