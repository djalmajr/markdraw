{
  "name": "asciimark",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:app": "bun run --filter @asciimark/desktop build",
    "build:ext": "bun run --filter @asciimark/extension build",
    "build:site": "bun run --filter @asciimark/site build",
    "dev:app": "bun run --filter @asciimark/desktop dev",
    "dev:ext": "bun run --filter @asciimark/extension dev",
    "dev:site": "bun run --filter @asciimark/site dev",
    "generate:icons": "bash scripts/generate-icons.sh",
    "bump:app": "bash scripts/bump-version.sh",
    "bump:ext": "bash scripts/bump-ext-version.sh",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "test:coverage": "bun run --filter '*' test:coverage",
    "test:bench": "bun run --filter '*' test:bench",
    "test:rust": "cd apps/desktop/src-tauri && cargo test",
    "test:rust:stress": "cd apps/desktop/src-tauri && cargo test --lib -- --ignored",
    "test:loom": "cd tools/loom-watcher-tests && RUSTFLAGS=\"--cfg loom\" cargo test --release",
    "test:miri": "cd apps/desktop/src-tauri && cargo +nightly miri test --lib interpolate_frame_endpoints",
    "test:mutation:rust": "cd apps/desktop/src-tauri && cargo mutants --no-shuffle --timeout 60",
    "audit:js": "bun audit --prod",
    "audit:rust": "cd apps/desktop/src-tauri && cargo audit",
    "audit": "bun run audit:js && bun run audit:rust",
    "type-coverage": "bun run --filter '@asciimark/core' type-coverage",
    "cov:rust": "cd apps/desktop/src-tauri && cargo llvm-cov --lib --html --open",
    "cov:rust:summary": "cd apps/desktop/src-tauri && cargo llvm-cov --lib --summary-only",
    "bench:rust": "cd apps/desktop/src-tauri && cargo bench",
    "bench:rust:read-dir": "cd apps/desktop/src-tauri && cargo bench --bench read_dir",
    "release:check": "bash scripts/release-check.sh",
    "test:approve": "APPROVE=1 bun test packages/core/src/__golden__",
    "test:contract": "bash scripts/check-ipc-contract.sh",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^1.10.10",
    "type-coverage": "^2.29.7"
  }
}
