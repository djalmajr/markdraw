        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "plugins": {
    "updater": {
      "active": false
    }
  }
