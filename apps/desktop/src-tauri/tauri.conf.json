{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Markdraw",
  "version": "0.23.2",
  "identifier": "app.markdraw",
  "build": {
    "beforeDevCommand": "bun run dev:frontend",
    "beforeBuildCommand": "bun run build:frontend",
    "devUrl": "http://127.0.0.1:2444",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Markdraw",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/tray-icon.png",
      "icons/tray-icon@2x.png"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdown"
        ],
        "mimeType": "text/markdown",
        "role": "Editor",
        "description": "Markdown Document"
      },
      {
        "ext": [
          "adoc",
          "asciidoc",
          "asc",
          "ad"
        ],
        "mimeType": "text/plain",
        "role": "Editor",
        "description": "AsciiDoc Document"
      }
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/djalmajr/markdraw/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZCRjk1MjBBMDM2MDA4MDYKUldRR0NHQURDbEw1Ky9IUHBpZWVaaVJxNFVveXZmQzZ1ZzdYTjRLYWNtb3RPSFEzMzB6RkNNRmQK"
    }
  }
}
