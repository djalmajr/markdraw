{
  "identifier": "default",
  "description": "Default capabilities for AsciiMark desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "dialog:default",
    "dialog:allow-open",
    "clipboard-manager:allow-write-text"
  ]
}
