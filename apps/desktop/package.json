{
  "name": "@markdraw/desktop",
  "version": "0.22.0-1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "macos:dev-signing": "bash scripts/macos-dev-signing-setup.sh",
    "dev:frontend": "bun run prepare:excalidraw && vite",
    "build": "tauri build",
    "build:frontend": "bun run prepare:excalidraw --force && vite build",
    "prepare:excalidraw": "node scripts/prepare-excalidraw-guest.mjs",
    "typecheck": "tsc --noEmit",
    "test": "bun test e2e/specs",
    "test:e2e": "bun test e2e/specs",
    "test:memlab": "bunx memlab run --scenario e2e/memory/scenario.cjs"
  },
  "dependencies": {
    "@markdraw/ai": "workspace:*",
    "@markdraw/core": "workspace:*",
    "@markdraw/diagram": "workspace:*",
    "@markdraw/i18n": "workspace:*",
    "@markdraw/ui": "workspace:*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@zomme/frame": "^1.2.4",
    "pdfjs-dist": "^5.7.284",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.441",
    "@tauri-apps/cli": "^2",
    "@types/bun": "latest",
    "@types/node": "^25.3.0",
    "memlab": "^2.0.2",
    "@tailwindcss/vite": "^4",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.10"
  }
}
